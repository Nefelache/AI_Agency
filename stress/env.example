# Copy to your shell or systemd EnvironmentFile before running ./stress/run.sh
# Values must match the API process (see my_agent_os/config/.env on the server).

# Target API (use public URL or reverse proxy on the server)
# BASE_URL=http://127.0.0.1:8000
# BASE_URL=https://your-domain.example

# Optional: same value as API_KEY_OWNER in server .env — enables memory + extended health phases
# API_KEY_OWNER=your-owner-key

# Load per phase (GET/POST parallel phases share this total)
# STRESS_TOTAL_REQUESTS=2000

# Thread pool size
# STRESS_CONCURRENCY=20

# Sequential registrations (SQLite write path); set 0 to skip
# STRESS_AUTH_REGISTER_COUNT=20

# Output directory (default: <repo>/stress/results)
# STRESS_RESULTS_DIR=/var/log/agent-os-stress

# Exit 2 if any phase has errors (default on). Set to 0 for “best effort” metrics only.
# STRESS_FAIL_ON_ERROR=1
