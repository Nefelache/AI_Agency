# Agent OS — Environment Template
# Copy to .env in this directory and fill in values

# --- LLM (DeepSeek) ---
DEEPSEEK_API_KEY=your-deepseek-api-key
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_BASE_URL=https://api.deepseek.com
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# --- Auth ---
API_KEY_OWNER=your-owner-key
API_KEY_CHANNEL=your-channel-key
API_KEY_GUEST=your-guest-key

# --- Memory V2 (MemoryPalace style) ---
MEMORY_V2_ENABLED=true
MEMORY_V2_DB_PATH=my_agent_os/memory_layer/data/memory_v2.db

# --- WhatsApp ---
WHATSAPP_ALLOW_FROM=+15551234567
WHATSAPP_BRIDGE_SECRET=your-random-secret

# --- Video Pipeline (matrix_planner + render_worker) ---
# Point to wherever A1111 is running (local Mac, ngrok tunnel, etc.)
A1111_URL=http://127.0.0.1:7860
RENDER_OUTPUT_DIR=/app/renders
RENDER_STEPS=20
RENDER_HW_ACCEL=0
